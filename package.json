{
  "name": "shortless",
  "version": "1.1.0",
  "private": true,
  "scripts": {
    "build": "node scripts/build.js",
    "build:chrome": "node scripts/build.js chrome",
    "build:firefox": "node scripts/build.js firefox",
    "pretest": "npm run build",
    "test": "npx playwright test",
    "test:offline": "npm run build && npx playwright test --project=offline",
    "test:network": "npm run build && npx playwright test --project=network",
    "test:report": "npx playwright show-report",
    "lint:firefox": "web-ext lint --source-dir packages/extension-firefox/",
    "firefox:dev": "web-ext run --source-dir packages/extension-firefox/"
  },
  "devDependencies": {
    "@playwright/test": "^1.50.0",
    "archiver": "^7.0.1",
    "typescript": "^5.7.0",
    "web-ext": "^10.0.0"
  }
}
