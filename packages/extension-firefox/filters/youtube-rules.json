[
  {
    "id": 1,
    "priority": 1,
    "action": {
      "type": "redirect",
      "redirect": {
        "regexSubstitution": "https://www.youtube.com/watch?v=\\1"
      }
    },
    "condition": {
      "regexFilter": "^https?://(?:www\\.|m\\.)?youtube\\.com/shorts/([a-zA-Z0-9_-]{11})",
      "resourceTypes": ["main_frame"]
    }
  },
  {
    "id": 2,
    "priority": 1,
    "action": {
      "type": "block"
    },
    "condition": {
      "urlFilter": "||youtube.com/youtubei/v1/reel/",
      "resourceTypes": ["xmlhttprequest"]
    }
  }
]
